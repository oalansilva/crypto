# Backend .env template
# Copy this to .env and fill in your Supabase credentials

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# API (optional overrides)
# API_TITLE=Crypto Backtester API
# API_VERSION=1.0.0

# Workflow DB (Postgres-first; used by /api/workflow/*)
# Enable the workflow DB (otherwise workflow endpoints return 503)
# WORKFLOW_DB_ENABLED=1
# Example (VPS local Postgres)
# WORKFLOW_DATABASE_URL=postgresql+psycopg2://workflow_app:<PASSWORD>@127.0.0.1:5432/workflow
