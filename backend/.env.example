# Backend .env template
# Copy this to .env and fill in your runtime credentials

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Main app DB (PostgreSQL only)
DATABASE_URL=postgresql+psycopg2://crypto_app:<PASSWORD>@127.0.0.1:5432/crypto_app

# API (optional overrides)
# API_TITLE=Crypto Backtester API
# API_VERSION=1.0.0

# Workflow DB for the standalone crypto project (PostgreSQL only)
WORKFLOW_DB_ENABLED=1
WORKFLOW_DATABASE_URL=postgresql+psycopg2://crypto_workflow:<PASSWORD>@127.0.0.1:5432/crypto_workflow

# Crypto runtime
CRYPTO_ROOT_DIRECTORY=/root/.openclaw/workspace/crypto
CRYPTO_DATABASE_URL=postgresql+psycopg2://crypto_app:<PASSWORD>@127.0.0.1:5432/crypto_app
CRYPTO_FRONTEND_URL=http://127.0.0.1:5173
CRYPTO_BACKEND_URL=http://127.0.0.1:8003
CRYPTO_WORKFLOW_DATABASE_URL=postgresql+psycopg2://crypto_workflow:<PASSWORD>@127.0.0.1:5432/crypto_workflow
