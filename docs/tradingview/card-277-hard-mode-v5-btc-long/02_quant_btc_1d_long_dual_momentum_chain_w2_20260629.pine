//@version=5
strategy("BTC 1D LONG WINNER 2 - Momentum Duplo de Continuidade", overlay=true, initial_capital=100, default_qty_type=strategy.percent_of_equity, default_qty_value=100, pyramiding=0)
fast = ta.ema(close, 13)
slow = ta.ema(close, 144)
rocFast = ta.roc(close, 8)
rocSlow = ta.roc(close, 30)
entry = fast > slow and rocFast > rocSlow and rocSlow > 0
exitSignal = fast < slow or rocFast < 0
if entry and strategy.position_size == 0
    strategy.entry("Long", strategy.long)
if strategy.position_size > 0
    strategy.exit("Stop", "Long", stop=strategy.position_avg_price * (1 - 0.014))
if exitSignal and strategy.position_size > 0
    strategy.close("Long")
plot(fast, color=color.teal)
plot(slow, color=color.orange)
