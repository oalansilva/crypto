POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_MULTIPLE_DATABASES=crypto_app,workflow_registry,workflow_crypto
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/crypto_app
WORKFLOW_DB_ENABLED=1
WORKFLOW_DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/workflow_registry
CRYPTO_DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/crypto_app
CRYPTO_WORKFLOW_DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/workflow_crypto

BACKEND_PORT=8003
FRONTEND_PORT=5173
# Optional if you need to override the frontend URL seen by the backend:
# CRYPTO_FRONTEND_URL=http://localhost:5173
CRYPTO_BACKEND_URL=http://backend:8003
VITE_API_URL=/api
VITE_DEV_PROXY_TARGET=http://backend:8003

RUN_SIGNAL_MONITOR=1
RUN_SIGNAL_FEED_SNAPSHOT_WORKER=1
WORKER_LOG_LEVEL=INFO

BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=7
BACKUP_ON_STARTUP=1
